nook() {
    export NOOK=$1

    if [[ -d ~/.kube/${NOOK} ]] ; then
        export KUBECONFIG="$HOME/.kube/${NOOK}/kubeconfig"
    else
        export KUBECONFIG="$HOME/.kube/config.${NOOK}"
    fi

    # Default color -- specific nooks may override
    export NOOK_COLOR=7

    if [[ -n "${NOOK_HANDLER}" ]] ; then
        if [[ -r "${NOOK_HANDLER}" ]] ; then
            source "${NOOK_HANDLER}"
        else
            echo "ERROR: Unable to read ${NOOK_HANDLER}." >&2
            return 2
        fi
    fi

    if [[ -n "${TMUX}" ]] ; then
        # NOTE: These options are also set in .zshrc to ensure passing them along to new tmux sessions
        tmux set-option @nook "${NOOK}"
        tmux set-environment NOOK "${NOOK}"

        tmux set-option @nook_style "bg=$NOOK_COLOR"
        tmux set-environment NOOK_COLOR "${NOOK_COLOR}"
    fi
}
